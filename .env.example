# CloudCode Environment Configuration
# Copy this file to .env and fill in the values

# Server
PORT=3000
HOST=0.0.0.0
APP_BASE_URL=http://localhost:3000

# Database
DATABASE_PATH=./data/cloudcode.db

# Security - generate with: openssl rand -hex 64
SESSION_SECRET=change-me-to-a-random-64-character-hex-string

# Tailscale (optional) - comma-separated list of allowed tailnet identities
# Leave empty to disable Tailscale identity validation
# Example: user@github,admin@example.com
TAILSCALE_ALLOWED_IDENTITIES=

# tmux binary path (optional, defaults to 'tmux')
TMUX_BINARY_PATH=tmux

# Terminal polling interval in ms (default: 500)
TERMINAL_POLL_INTERVAL_MS=500
